# Nusxa: bu faylni .env nomiga saqlang va qiymatlarni to‘ldiring
# Vite faqat .env faylini yuklaydi — .env.example ishlamaydi

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_JWT_KEY

# Dashboard → Settings → API: "anon" "public" kalit (odatda eyJ... bilan boshlanadi)
# Agar faqat "publishable" ko‘rsatilsa, Supabase yangilangan kalitni qo‘llab-quvvatlaydi;
# ishlamasa — legacy anon JWT ni ishlating.

VITE_SITE_NAME=Katalog

# Telegram/WhatsApp havolasi: doim shu domen ishlatiladi (masalan Vercel).
# Localhostda yuborilsa, admin telefonda ocholmaydi — ishlab chiqarish URL qo‘ying.
# VITE_SHARE_BASE_URL=https://nuur-home1.vercel.app

# Boshlang‘ich til: uz | ru | en (headerda almashtirish localStorage da saqlanadi)
VITE_CATALOG_LANG=uz
